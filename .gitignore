# ---------------------------------------------------------------------------
# Local configuration
# ---------------------------------------------------------------------------
# Keep real local config out of commits. Commit .env.example instead.
.env
!.env.example


# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/


# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.conda/
.venv/
venv/
env/
ENV/


# ---------------------------------------------------------------------------
# Runtime logs and generated state
# ---------------------------------------------------------------------------
logs/
*.log
*.log.*
*.pid
*.pid.json
*.jsonl


# ---------------------------------------------------------------------------
# SQLite databases
# ---------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal
*.db
*.db-shm
*.db-wal


# ---------------------------------------------------------------------------
# Browser / visual-check generated files
# ---------------------------------------------------------------------------
chrome-*-profile/
screenshots/
*.tmp.png


# ---------------------------------------------------------------------------
# Node / frontend build artifacts
# ---------------------------------------------------------------------------
node_modules/
dist/
build/
.parcel-cache/
.vite/


# ---------------------------------------------------------------------------
# Editor and OS noise
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.idea/
.DS_Store
Thumbs.db
desktop.ini


# ---------------------------------------------------------------------------
# Temporary files
# ---------------------------------------------------------------------------
*.tmp
*.temp
preference.md
test
prompts/versions
*.bak
*.swp
~$*
