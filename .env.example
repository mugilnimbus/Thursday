# Thursday agent configuration

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Dashboard bind address and port.
SERVER_HOST=127.0.0.1
SERVER_PORT=8787

# Static frontend files.
STATIC_DIR=web


# ---------------------------------------------------------------------------
# Agent Identity
# ---------------------------------------------------------------------------
AGENT_NAME=thursday


# ---------------------------------------------------------------------------
# LM Studio
# ---------------------------------------------------------------------------
# Local LM Studio endpoint and model id.
# Thursday uses the OpenAI-compatible endpoint:
#   POST {LMSTUDIO_ENDPOINT}/v1/chat/completions
LMSTUDIO_ENDPOINT=http://127.0.0.1:1234
LMSTUDIO_MODEL=qwen3.5-9b-mtp

# Request timeout for chat completions.
LLM_TIMEOUT_SECONDS=180

# Stop sequences sent to LM Studio.
LLM_STOP_SEQUENCES=<|im_end|>,<|observation|>,<|end|>

# Status check timeout for /v1/models.
STATUS_TIMEOUT_SECONDS=5


# ---------------------------------------------------------------------------
# Default Model Settings
# ---------------------------------------------------------------------------
DEFAULT_TEMPERATURE=0.8
DEFAULT_TOP_P=0.9
DEFAULT_REPETITION_PENALTY=1.1
DEFAULT_MAX_TOKENS=32000
DEFAULT_CONTEXT_WINDOW=100000
DEFAULT_MAX_STEPS=8
DEFAULT_ENABLE_THINKING=true
DEFAULT_STREAM=false


# ---------------------------------------------------------------------------
# Docker Workspace
# ---------------------------------------------------------------------------
# The agent works only inside this Ubuntu Docker container.
DOCKER_CONTAINER_NAME=Thursday
DOCKER_IMAGE=ubuntu:24.04
DOCKER_WORKDIR=/workspace
DOCKER_COMMAND_TIMEOUT_SECONDS=120


# ---------------------------------------------------------------------------
# Prompts And Frontend Tools
# ---------------------------------------------------------------------------
PROMPT_DIR=prompts
VISUAL_CHECK_DIR=logs/visual_checks

# Optional explicit browser executable for visual checks. Leave empty to auto-detect.
BROWSER_EXECUTABLE=


# ---------------------------------------------------------------------------
# Logs, Database, And Preferences
# ---------------------------------------------------------------------------
LOG_DIR=logs
LOG_DB_FILE=thursday_logs.sqlite3
PREFERENCES_FILE=dashboard_preferences.json

# Legacy JSONL import remains for older raw LM Studio logs.
LMSTUDIO_RAW_LOG_ENABLED=true
LMSTUDIO_RAW_LOG_FILE=lmstudio_raw.jsonl


# ---------------------------------------------------------------------------
# Tool Output Limits
# ---------------------------------------------------------------------------
TOOL_MAX_OUTPUT_CHARS=100000
TOOL_MAX_ERROR_CHARS=100000
TOOL_OBSERVATION_MAX_CHARS=100000


# ---------------------------------------------------------------------------
# Context Management
# ---------------------------------------------------------------------------
# Prune when estimated context reaches this fraction of DEFAULT_CONTEXT_WINDOW.
CONTEXT_PRUNE_RATIO=0.9

# write_file content over this size is kept for one post-tool LLM pass,
# then replaced in context with an LLM-written brief.
WRITE_FILE_SUMMARY_MIN_CHARS=500
WRITE_FILE_SUMMARY_MAX_TOKENS=300

# Token budget used when the LLM summarizes old conversation context.
CONTEXT_SUMMARY_MAX_TOKENS=100000

# Number of timeline events kept in memory/session state.
EVENT_HISTORY_LIMIT=200
